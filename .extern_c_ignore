# #ifdef __cplusplus / extern "C" guards.
#
# Reasons a header might not need the guard:
#   - Contains only preprocessor macros / #defines
#   - Contains only typedefs or static inline functions
#   - Is a C++-only header (not part of the C API)
#   - Is an internal/generated header not consumed by user code
